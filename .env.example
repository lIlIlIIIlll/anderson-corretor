# === Banco de dados (Neon Postgres) ===
# Connection string do Neon (use o endpoint "pooled", região sa-east-1 / São Paulo)
DATABASE_URL=postgres://USUARIO:SENHA@HOST.neon.tech/NOME_DB?sslmode=require

# === Payload ===
# Gere uma string aleatória longa (ex.: `openssl rand -hex 32`)
PAYLOAD_SECRET=gere-uma-string-aleatoria-longa
# URL pública do site (em produção, o domínio real)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# === Cloudinary (mídia / fotos dos imóveis) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Cloud name exposto ao front (usado pelo loader de imagem do next/image)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# === IA do chat ===
# Escolha o provider: "google" (Gemini — free tier) ou "openai-compatible" (OpenRouter/OpenAI/etc.)
AI_PROVIDER=google
# Chave da IA:
#  - Gemini (grátis): https://aistudio.google.com/apikey
#  - OpenRouter:      https://openrouter.ai/keys
AI_API_KEY=
# Modelo:
#  - Gemini:     gemini-2.0-flash (ou gemini-2.5-flash, etc.)
#  - OpenRouter: openai/gpt-4o-mini, etc.
AI_MODEL=gemini-2.0-flash
# Usado apenas quando AI_PROVIDER=openai-compatible:
AI_BASE_URL=https://openrouter.ai/api/v1

# === Contato do corretor ===
# Número no formato internacional, só dígitos (ex.: 5511999998888)
BROKER_WHATSAPP=55XXXXXXXXXXX
